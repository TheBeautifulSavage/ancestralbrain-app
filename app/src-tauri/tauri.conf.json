{
  "productName": "Ancestral Brain",
  "version": "0.1.0",
  "identifier": "com.ancestralbrain.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Ancestral Brain Alpha — Producer Vault",
        "width": 960,
        "height": 680,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "url": "onboarding.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src http://localhost:11434"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "wix": {},
      "nsis": {}
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
